// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sessions  Session[]
  chats     Chat[]
  memories  Memory[]
  profiles  Profile[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  answers   Json
  results   Json
  simulations Simulation[]
  user      User     @relation(fields: [userId], references: [id])
}

model Simulation {
  id        String   @id @default(uuid())
  sessionId String
  createdAt DateTime @default(now())
  data      Json
  session   Session  @relation(fields: [sessionId], references: [id])
}

model Chat {
  id        String   @id @default(uuid())
  userId    String
  sessionId String?
  message   String
  response  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model GlobalIndex {
  id        String   @id @default(uuid())
  type      String
  value     Float
  timestamp DateTime @default(now())
}

model Memory {
  id          String   @id @default(uuid())
  userId      String
  title       String
  content     String?
  type        String   // story, voice, values
  embedding   String?  // vector embedding
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}

model Profile {
  id              String   @id @default(uuid())
  userId          String
  archetype       String   // impact archetype classification
  psychologicalProfile Json  // embedding-based profile
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])
}